# 应用设置：仅用于本地开发，生产环境必须覆盖 debug 和 OpenAPI 开关。
EDA_APP__ENVIRONMENT=development
EDA_APP__DEBUG=false
EDA_APP__HOST=127.0.0.1
EDA_APP__PORT=8000
EDA_APP__OPENAPI_ENABLED=true

# 日志和指标设置。JSON 日志适合被采集器消费；本地默认使用可读格式。
EDA_LOGGING__LEVEL=INFO
EDA_LOGGING__JSON_OUTPUT=false
EDA_METRICS__ENABLED=true
EDA_METRICS__PATH=/metrics

# 示例密钥只允许本地使用。真实密钥必须由安全配置中心或环境变量注入。
EDA_AUTH__ENABLED=true
EDA_AUTH__API_KEYS=[{"key":"replace-local-api-key","user_id":"local-operator","roles":["operator"]}]
# smoke.sh 使用同一示例值发起受保护请求；它不是应用配置字段。
EDA_SMOKE_API_KEY=replace-local-api-key

# 八类 Provider 在阶段 1 默认使用 mock；real 只建立配置，不执行真实接入。
EDA_PROVIDERS__DEVICE_PROFILE=mock
EDA_PROVIDERS__ALARM=mock
EDA_PROVIDERS__TIMESERIES=mock
EDA_PROVIDERS__MANUAL_SEARCH=mock
EDA_PROVIDERS__TICKET_SEARCH=mock
EDA_PROVIDERS__GRAPH_RELATION=mock
EDA_PROVIDERS__TICKET_WRITE=mock
EDA_PROVIDERS__CASE_REVIEW=mock

# 后续阶段使用的模型与检索配置。阶段 1 只验证结构，不发起调用。
EDA_MODEL__MODEL_NAME=not-configured
EDA_MODEL__ENDPOINT=
EDA_MODEL__TIMEOUT_SECONDS=30
EDA_RETRIEVAL__KEYWORD_BACKEND=opensearch
EDA_RETRIEVAL__FINAL_TOP_K=5
EDA_RETRIEVAL__SCORE_THRESHOLD=0.45

# 依赖探测设置。enabled 控制是否探测，required 控制失败是否阻断 readiness。
EDA_DEPENDENCIES__MYSQL__ENABLED=true
EDA_DEPENDENCIES__MYSQL__REQUIRED=true
EDA_DEPENDENCIES__MYSQL__PROTOCOL=tcp
EDA_DEPENDENCIES__MYSQL__HOST=127.0.0.1
EDA_DEPENDENCIES__MYSQL__PORT=3306
EDA_DEPENDENCIES__REDIS__ENABLED=true
EDA_DEPENDENCIES__REDIS__REQUIRED=true
EDA_DEPENDENCIES__REDIS__PROTOCOL=redis
EDA_DEPENDENCIES__REDIS__HOST=127.0.0.1
EDA_DEPENDENCIES__REDIS__PORT=6379
EDA_DEPENDENCIES__MINIO__ENABLED=true
EDA_DEPENDENCIES__MINIO__REQUIRED=true
EDA_DEPENDENCIES__MINIO__PROTOCOL=http
EDA_DEPENDENCIES__MINIO__URL=http://127.0.0.1:9000/minio/health/ready
EDA_DEPENDENCIES__RABBITMQ__ENABLED=true
EDA_DEPENDENCIES__RABBITMQ__REQUIRED=true
EDA_DEPENDENCIES__RABBITMQ__PROTOCOL=tcp
EDA_DEPENDENCIES__RABBITMQ__HOST=127.0.0.1
EDA_DEPENDENCIES__RABBITMQ__PORT=5672
EDA_DEPENDENCIES__MILVUS__ENABLED=true
EDA_DEPENDENCIES__MILVUS__REQUIRED=true
EDA_DEPENDENCIES__MILVUS__PROTOCOL=tcp
EDA_DEPENDENCIES__MILVUS__HOST=127.0.0.1
EDA_DEPENDENCIES__MILVUS__PORT=19530
EDA_DEPENDENCIES__NEO4J__ENABLED=true
EDA_DEPENDENCIES__NEO4J__REQUIRED=true
EDA_DEPENDENCIES__NEO4J__PROTOCOL=tcp
EDA_DEPENDENCIES__NEO4J__HOST=127.0.0.1
EDA_DEPENDENCIES__NEO4J__PORT=7687
EDA_DEPENDENCIES__INFLUXDB__ENABLED=true
EDA_DEPENDENCIES__INFLUXDB__REQUIRED=true
EDA_DEPENDENCIES__INFLUXDB__PROTOCOL=http
EDA_DEPENDENCIES__INFLUXDB__URL=http://127.0.0.1:8086/health
EDA_DEPENDENCIES__OPENSEARCH__ENABLED=true
EDA_DEPENDENCIES__OPENSEARCH__REQUIRED=true
EDA_DEPENDENCIES__OPENSEARCH__PROTOCOL=http
EDA_DEPENDENCIES__OPENSEARCH__URL=http://127.0.0.1:9200/_cluster/health
EDA_HEALTH__PROBE_TIMEOUT_SECONDS=2

# Compose 本地凭据。这里都是可替换示例，禁止用于共享或生产环境。
# 所有宿主端口默认只绑定 loopback；仅在受控环境中才可覆盖 EDA_BIND_HOST。
EDA_BIND_HOST=127.0.0.1
# 宿主端口均可覆盖，容器间仍使用标准端口；发生本机冲突时只需修改对应变量。
EDA_APP_PORT=8000
EDA_MYSQL_PORT=3306
EDA_REDIS_PORT=6379
EDA_MINIO_API_PORT=9000
EDA_MINIO_CONSOLE_PORT=9001
EDA_RABBITMQ_PORT=5672
EDA_RABBITMQ_CONSOLE_PORT=15672
EDA_MILVUS_PORT=19530
EDA_MILVUS_HEALTH_PORT=9091
EDA_NEO4J_HTTP_PORT=7474
EDA_NEO4J_BOLT_PORT=7687
EDA_INFLUXDB_PORT=8086
EDA_OPENSEARCH_PORT=9200
EDA_OPENSEARCH_METRICS_PORT=9600
MYSQL_ROOT_PASSWORD=replace-mysql-root
MYSQL_DATABASE=energy_diagnosis
MYSQL_USER=energy_app
MYSQL_PASSWORD=replace-mysql-password
MINIO_ROOT_USER=energy-minio
MINIO_ROOT_PASSWORD=replace-minio-password
RABBITMQ_DEFAULT_USER=energy-rabbit
RABBITMQ_DEFAULT_PASS=replace-rabbit-password
NEO4J_AUTH=neo4j/replace-neo4j-password
INFLUXDB_ADMIN_USER=energy-admin
INFLUXDB_ADMIN_PASSWORD=replace-influx-password
INFLUXDB_ADMIN_TOKEN=replace-influx-token
