RETRIEVAL_VECTOR_WEIGHT=0.40
RETRIEVAL_RERANK_WEIGHT=0.30
FINAL_RETRIEVAL_WEIGHT=0.35
FINAL_SOURCE_RELIABILITY_WEIGHT=0.20
FINAL_VERIFICATION_WEIGHT=0.15
FINAL_RELEVANCE_TO_ALARM_WEIGHT=0.15
FINAL_FRESHNESS_WEIGHT=0.15
