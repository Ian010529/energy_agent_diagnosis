APP_NAME=energy-agent
APP_ENV=local
LOG_LEVEL=INFO
LOG_FORMAT=console
MYSQL_DSN=mysql+asyncmy://energy:energy_dev@localhost:3306/energy_agent
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=86400
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=energy-token
INFLUXDB_ORG=energy
INFLUXDB_BUCKET=energy_metrics
INFLUXDB_QUERY_TIMEOUT_SECONDS=5
DEFAULT_DIAGNOSIS_WINDOW_MINUTES=30
MODEL_MODE=disabled
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
MODEL_GATEWAY_BASE_URL=
MODEL_GATEWAY_API_KEY=
MODEL_NAME=gpt-5.6-terra
MODEL_TIMEOUT_SECONDS=15
MODEL_TEMPERATURE=0.2
OBSERVABILITY_MODE=local
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
TRACE_CONTENT_MODE=metadata_only
RETRIEVAL_MODE=keyword_only
QUERY_REWRITE_MODE=rules
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=energy
MINIO_SECRET_KEY=energy_minio_dev
MINIO_BUCKET_DOCUMENTS=energy-documents
MINIO_SECURE=false
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_MANUAL_COLLECTION=manual_chunks
MILVUS_TICKET_COLLECTION=ticket_cases
MILVUS_VECTOR_DIMENSION=1024
MILVUS_METRIC_TYPE=COSINE
EMBEDDING_MODE=disabled
EMBEDDING_BASE_URL=https://api.siliconflow.cn
EMBEDDING_API_KEY=
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT_SECONDS=15
EMBEDDING_BATCH_SIZE=16
RERANK_MODE=disabled
RERANK_BASE_URL=https://api.siliconflow.cn
RERANK_API_KEY=
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_TIMEOUT_SECONDS=15
RERANK_TOP_N=30
MANUAL_KEYWORD_TOP_N=20
MANUAL_VECTOR_TOP_N=20
TICKET_KEYWORD_TOP_N=20
TICKET_VECTOR_TOP_N=20
RERANK_INPUT_SIZE=30
MANUAL_FINAL_TOP_K=5
TICKET_FINAL_TOP_K=5
MANUAL_SIMILARITY_THRESHOLD=0.45
TICKET_SIMILARITY_THRESHOLD=0.50
SEMANTIC_DEDUP_THRESHOLD=0.92
MAX_CHUNKS_PER_DOCUMENT=2
MAX_RESULTS_PER_TICKET=1
